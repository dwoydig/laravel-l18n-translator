{
    "name": "dwoydig/l18n-translator",
    "description": "Laravel package to manage JSON language files via a web UI with optional DeepL auto-translation.",
    "keywords": ["laravel", "translation", "i18n", "l10n", "deepl", "json"],
    "type": "library",
    "license": "MIT",
    "authors": [
        {
            "name": "Daniel Woydig",
            "email": "dwoydig@gmail.com"
        }
    ],
    "require": {
        "php": "^8.1",
        "ext-intl": "*",
        "illuminate/support": "^10.0|^11.0|^12.0",
        "illuminate/http": "^10.0|^11.0|^12.0",
        "illuminate/routing": "^10.0|^11.0|^12.0",
        "illuminate/filesystem": "^10.0|^11.0|^12.0"
    },
    "autoload": {
        "psr-4": {
            "Dwoydig\\L18nTranslator\\": "src/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "Dwoydig\\L18nTranslator\\TranslationServiceProvider"
            ]
        }
    },
    "minimum-stability": "dev",
    "prefer-stable": true
}
